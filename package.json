{
  "name": "feature-harness",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @harness/api dev\" \"pnpm --filter @harness/web dev\"",
    "dev:api": "pnpm --filter @harness/api dev",
    "dev:web": "pnpm --filter @harness/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
