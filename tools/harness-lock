#!/usr/bin/env node
// harness-lock — CLI for agents to acquire/release the global heavy-stage lock
// Uses the harness API (localhost:HARNESS_PORT) to coordinate across lanes.
// Usage: harness-lock acquire <laneSlug>
//        harness-lock release <laneSlug>

const http = require("http");

const HARNESS_PORT = process.env.HARNESS_PORT || 8090;
const POLL_MS = 2000;
const TIMEOUT_MS = 300_000; // 5 min max wait

function httpRequest(method, path, body) {
  return new Promise((resolve, reject) => {
    const opts = {
      hostname: "host.docker.internal",
      port: HARNESS_PORT,
      path,
      method,
      headers: { "Content-Type": "application/json" },
    };
    const req = http.request(opts, (res) => {
      let data = "";
      res.on("data", (c) => data += c);
      res.on("end", () => {
        try { resolve({ status: res.statusCode, body: JSON.parse(data) }); }
        catch { resolve({ status: res.statusCode, body: data }); }
      });
    });
    req.on("error", reject);
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

async function acquire(slug) {
  const start = Date.now();
  console.log(`[harness-lock] acquiring heavy_stage lock for ${slug}...`);

  while (Date.now() - start < TIMEOUT_MS) {
    try {
      const res = await httpRequest("POST", `/api/locks/acquire`, { lockType: "heavy_stage", slug });
      if (res.status === 200 && res.body.acquired) {
        console.log(`[harness-lock] acquired for ${slug}`);
        return;
      }
      console.log(`[harness-lock] waiting... (held by lane ${res.body.heldBy || "unknown"})`);
    } catch (err) {
      console.error(`[harness-lock] API error: ${err.message}, retrying...`);
    }
    await new Promise(r => setTimeout(r, POLL_MS));
  }

  console.error(`[harness-lock] timeout acquiring lock for ${slug}`);
  process.exit(1);
}

async function release(slug) {
  try {
    const res = await httpRequest("POST", `/api/locks/release`, { lockType: "heavy_stage", slug });
    if (res.status === 200) {
      console.log(`[harness-lock] released for ${slug}`);
    } else {
      console.error(`[harness-lock] release failed: ${JSON.stringify(res.body)}`);
    }
  } catch (err) {
    console.error(`[harness-lock] API error: ${err.message}`);
    process.exit(1);
  }
}

async function main() {
  const [action, slug] = process.argv.slice(2);

  if (!action || !slug || !["acquire", "release"].includes(action)) {
    console.error("Usage: harness-lock <acquire|release> <laneSlug>");
    process.exit(1);
  }

  if (action === "acquire") await acquire(slug);
  else await release(slug);
}

main();
